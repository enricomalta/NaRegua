rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
      // ========================================
      // 🔒 ZERO-TRUST POLICY
      // ========================================
      // Por padrão, BLOQUEAR TUDO.
      // Todas as operações devem passar por APIs server-side.
      // Metodo Security Acess

      // ========================================
      // 🚫 BLOQUEIO TOTAL: Todas Coleções
      // ========================================
      // TUDO via API server-side (Firebase Admin SDK)
    }
  }
}